db.member.aggregate([
  {
    $project: {
      periods: { $objectToArray: "$participationPeriods" }
    }
  },
  {
    $unwind: "$periods"
  },
  {
    $group: {
      _id: {
        $dateToString: {
          format: "%Y-%m",
          date: { $toDate: "$periods.k" }
        }
      },
      count: { $sum: 1 }
    }
  },
  {
    $sort: { _id: 1 }
  }
])
